<Window x:Class="GasStationApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="430"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource ColorBackground}"
        KeyDown="Window_KeyDown">

    <Grid>
        <Border Width="360"
                Background="White"
                CornerRadius="18"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Gas Station"
                           FontSize="28"
                           FontWeight="ExtraBold"
                           Foreground="{StaticResource ColorDarkNavy}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Авторизация пользователя"
                           FontSize="14"
                           Foreground="{StaticResource ColorMutedGrey}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="TxtLogin"
                         Height="36"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Пароль"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="TxtPassword"
                             Height="36"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,10"/>

                <TextBlock x:Name="TxtError"
                           Text=""
                           Foreground="#C0392B"
                           FontSize="13"
                           TextWrapping="Wrap"
                           MinHeight="35"
                           Margin="0,5,0,10"/>

                <Button Content="Войти"
                        Height="40"
                        Click="BtnLogin_Click"/>

                <TextBlock Text="Тестовые пользователи: admin / cashier / manager"
                           Foreground="{StaticResource ColorMutedGrey}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

                <TextBlock Text="Пароли: admin123 / cashier123 / manager123"
                           Foreground="{StaticResource ColorMutedGrey}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>