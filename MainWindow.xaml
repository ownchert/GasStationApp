<Window x:Class="GasStationApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АИС АЗС"
        Height="650"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorBackground}">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DCDCDC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ColorMutedGrey}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorMutedGrey}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="25,18,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВОЕ ФУНКЦИОНАЛЬНОЕ МЕНЮ -->
        <Border Grid.Column="0" Background="{StaticResource ColorDarkNavy}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Блок пользователя -->
                <StackPanel Grid.Row="0" Margin="25,25,20,15">
                    <TextBlock Text="Gas Station"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="ExtraBold"
                               FontFamily="Segoe UI Black"/>

                    <TextBlock x:Name="TxtUserInfo"
                               Text="Пользователь"
                               Foreground="White"
                               FontSize="13"
                               Margin="0,18,0,2"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="TxtRoleInfo"
                               Text="Роль"
                               Foreground="{StaticResource ColorMutedTeal}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Меню -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,15">

                        <TextBlock Text="ПРОДАЖИ" Style="{StaticResource MenuHeaderStyle}"/>

                        <Button x:Name="BtnProductSale"
                                Content="Оформить продажу товара"
                                Click="BtnProductSale_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnFuelSale"
                                Content="Оформить продажу топлива"
                                Click="BtnFuelSale_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnChecks"
                                Content="Журнал чеков"
                                Click="BtnCheck_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="ПОСТАВКИ" Style="{StaticResource MenuHeaderStyle}"/>
                        <Button x:Name="BtnProductSupply"
                                Content="Поставки товаров"
                                Click="BtnProductSupply_Click"
                                Style="{StaticResource MenuButtonStyle}"/>
                        <Button x:Name="BtnFuelSupply"
                                Content="Поставки топлива"
                                Click="BtnFuelSupply_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="СКЛАД И ОСТАТКИ" Style="{StaticResource MenuHeaderStyle}"/>

                        <Button x:Name="BtnStockControl"
                                Content="Контроль остатков"
                                Click="BtnStockControl_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnProducts"
                                Content="Товары и остатки"
                                Click="BtnProduct_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnFuel"
                                Content="Топливо и остатки"
                                Click="BtnFuel_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="СПРАВОЧНИКИ" Style="{StaticResource MenuHeaderStyle}"/>

                        <Button x:Name="BtnSuppliers"
                                Content="Поставщики"
                                Click="BtnSupplier_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnFuelColumns"
                                Content="Топливные колонки"
                                Click="BtnFuelColumns_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnEmployees"
                                Content="Сотрудники"
                                Click="BtnEmployee_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <TextBlock Text="АНАЛИТИКА" Style="{StaticResource MenuHeaderStyle}"/>
                        <Button x:Name="BtnReports"
                                Content="Отчеты"
                                Click="BtnReport_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Выход -->
                <StackPanel Grid.Row="2" Margin="10,10,10,20">
                    <Button Content="Выйти из аккаунта"
                            Height="38"
                            Background="{StaticResource ColorMutedLavender}"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ПРАВАЯ ЧАСТЬ -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>